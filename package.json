{
  "name": "codevamp-links",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev",
    "dev:turbo": "next dev --turbopack",
    "dev:bridge": "node scripts/local-shell-bridge.mjs",
    "supabase:migrations:verify": "node scripts/verify-supabase-migrations.mjs",
    "clean:next": "node -e \"const fs=require('fs');['.next','node_modules/.cache/next'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true}));\"",
    "dev:reset": "npm run clean:next && next dev",
    "dev:reset:turbo": "npm run clean:next && next dev --turbopack",
    "quality:release": "npm run lint && npm run build",
    "wasm:build:dev-engine": "wasm-pack build src/wasm/dev_engine --target web --out-dir ../../../public/wasm/pkg --release",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "@zxing/browser": "^0.1.5",
    "jszip": "^3.10.1",
    "next": "^15.5.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-qr-code": "^2.0.18"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.6",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
